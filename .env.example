# === Backend env (sao chép thành .env rồi điền giá trị thật) ===

# Bắt buộc hiện tại — chuỗi kết nối PostgreSQL
# vd: postgresql+psycopg2://user:password@localhost:5432/chuanword
SQLALCHEMY_DATABASE_URL=

# === Dưới đây là biến cho kiến trúc mục tiêu (chưa dùng tới ở GĐ hiện tại) ===

# Claude API — phân tích ngữ nghĩa
# ANTHROPIC_API_KEY=

# Object storage (S3) — lưu file .docx thay cho thư mục local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
# S3_BUCKET=

# Task queue (Celery + Redis)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Auth
# JWT_SECRET=
